HOST=0.0.0.0
PORT=3080

DOMAIN_CLIENT=https://chat.ayafinancial.com
DOMAIN_SERVER=https://chat.ayafinancial.com
APP_TITLE=Aya Financial Assistant

NO_INDEX=true
TRUST_PROXY=1
CONSOLE_JSON=true
DEBUG_LOGGING=false
DEBUG_CONSOLE=false

ENDPOINTS=openAI
OPENAI_API_KEY=replace-with-openai-api-key

CREDS_KEY=replace-with-64-char-hex
CREDS_IV=replace-with-32-char-hex
JWT_SECRET=replace-with-64-char-hex
JWT_REFRESH_SECRET=replace-with-64-char-hex
MEILI_MASTER_KEY=replace-with-64-char-hex

ALLOW_EMAIL_LOGIN=true
ALLOW_REGISTRATION=true
ALLOW_SOCIAL_LOGIN=false
ALLOW_SOCIAL_REGISTRATION=false
ALLOW_PASSWORD_RESET=false
ALLOW_UNVERIFIED_EMAIL_LOGIN=true

MONGO_URI=mongodb://mongodb:27017/LibreChat
