HOST=0.0.0.0
PORT=3080

DOMAIN_CLIENT=https://copilot.ayafinancial.com
DOMAIN_SERVER=https://copilot.ayafinancial.com
APP_TITLE=AYA Copilot

NO_INDEX=true
TRUST_PROXY=1
CONSOLE_JSON=true
DEBUG_LOGGING=false
DEBUG_CONSOLE=false

ENDPOINTS=openAI
OPENAI_API_KEY=replace-with-openai-api-key

CREDS_KEY=replace-with-64-char-hex
CREDS_IV=replace-with-32-char-hex
JWT_SECRET=replace-with-64-char-hex
JWT_REFRESH_SECRET=replace-with-64-char-hex
MEILI_MASTER_KEY=replace-with-64-char-hex

ALLOW_EMAIL_LOGIN=true
ALLOW_REGISTRATION=true
ALLOW_SOCIAL_LOGIN=false
ALLOW_SOCIAL_REGISTRATION=false
ALLOW_PASSWORD_RESET=false
ALLOW_UNVERIFIED_EMAIL_LOGIN=true

# Required when Google login is enabled. The callback path must match
# LibreChat's mounted OAuth route and the Google OAuth client redirect URI.
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_CALLBACK_URL=/oauth/google/callback

MONGO_URI=mongodb://mongodb:27017/LibreChat
