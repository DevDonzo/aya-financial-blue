{
  "name": "aya-ops-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:server && npm run build:admin-ui",
    "build:server": "tsc -p tsconfig.json",
    "build:admin-ui": "npm --prefix admin-ui run build",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/server.ts",
    "dev:admin-ui": "npm --prefix admin-ui run dev",
    "dev:mcp": "tsx src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^8.3.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@types/mongodb": "^4.0.6",
    "better-sqlite3": "^12.4.1",
    "fastify": "^5.6.0",
    "fastify-plugin": "^5.1.0",
    "fastify-raw-body": "^5.0.0",
    "kysely": "^0.28.2",
    "mongodb": "^7.1.1",
    "pino": "^9.9.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.3.0",
    "msw": "^2.11.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
